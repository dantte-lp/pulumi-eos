# Containerfile.dev — pulumi-eos development image.
# Spec: Containerfile.5 (https://github.com/containers/common/blob/main/docs/Containerfile.5.md).
# Buildable natively with Buildah and Podman build (no external frontend required).
#
# Build:   podman build -f deployments/containers/Containerfile.dev -t pulumi-eos-dev:local .
# Run via: deployments/compose/compose.dev.yml (Compose Specification).
#
# Image references are unqualified and resolved through Podman's
# unqualified-search-registries (see deployments/containers/registries.conf).

ARG GO_VERSION=1.26.2
ARG PULUMI_VERSION=3.150.0
ARG GOLANGCI_LINT_VERSION=v2.11.4
ARG GOVULNCHECK_VERSION=v1.2.0
ARG OSV_SCANNER_VERSION=v2.3.5
ARG NODE_MAJOR=22
ARG PODMAN_PY_VERSION=5.5.0

FROM golang:1.26.2-trixie AS dev

ARG PULUMI_VERSION
ARG GOLANGCI_LINT_VERSION
ARG GOVULNCHECK_VERSION
ARG OSV_SCANNER_VERSION
ARG NODE_MAJOR
ARG PODMAN_PY_VERSION

ENV GOFLAGS="-buildvcs=false" \
    GOCACHE=/tmp/go-cache \
    GOMODCACHE=/go/pkg/mod \
    PULUMI_SKIP_UPDATE_CHECK=true \
    NPM_CONFIG_UPDATE_NOTIFIER=false \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    DEBIAN_FRONTEND=noninteractive

LABEL org.opencontainers.image.title="pulumi-eos-dev" \
      org.opencontainers.image.description="Development image for pulumi-eos." \
      org.opencontainers.image.source="https://github.com/dantte-lp/pulumi-eos" \
      org.opencontainers.image.licenses="Apache-2.0"

# Base OS tooling.
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
        git \
        ca-certificates \
        tzdata \
        make \
        bash \
        curl \
        unzip \
        jq \
        gnupg \
        python3 \
        python3-pip \
 && rm -rf /var/lib/apt/lists/*

# Node.js (npm-based linters).
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    install -m 0755 -d /etc/apt/keyrings \
 && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
      | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
 && chmod a+r /etc/apt/keyrings/nodesource.gpg \
 && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
      > /etc/apt/sources.list.d/nodesource.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends nodejs \
 && rm -rf /var/lib/apt/lists/*

# Pulumi CLI (pinned).
RUN curl -fsSL https://get.pulumi.com | bash -s -- --version "${PULUMI_VERSION#v}" \
 && cp -r /root/.pulumi/bin/* /usr/local/bin/ \
 && rm -rf /root/.pulumi

# Go tooling.
RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg/mod \
    go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${GOLANGCI_LINT_VERSION} \
 && go install golang.org/x/vuln/cmd/govulncheck@${GOVULNCHECK_VERSION} \
 && go install github.com/google/osv-scanner/v2/cmd/osv-scanner@${OSV_SCANNER_VERSION} \
 && go install golang.org/x/perf/cmd/benchstat@latest \
 && go install gotest.tools/gotestsum@latest

# npm-based documentation linters (Markdown / cspell / commitlint).
# Mermaid render-lint (mmdc) is intentionally NOT installed here: it pulls in a
# headless Chromium with system libs (libnss3, libxkb, libgbm…) bloating the
# image. `make lint-mmd` runs mmdc on the host or in the CI lint-docs job.
RUN --mount=type=cache,target=/root/.npm \
    npm install -g \
        markdownlint-cli2@latest \
        cspell@latest \
        @commitlint/cli@latest \
        @commitlint/config-conventional@latest

# Python tooling: yamllint, junit2html, podman-py for automation parity.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --break-system-packages --no-cache-dir \
        yamllint \
        junit2html \
        "podman==${PODMAN_PY_VERSION}"

WORKDIR /app
VOLUME /app

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD pgrep -x sleep >/dev/null || exit 1

CMD ["sleep", "infinity"]
